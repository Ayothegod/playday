// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "sqlite"
}

model User {
  id          String @id
  name        String
  sports      String // sports they play - JSON.stringify([])
  skillLevel  String @default("begineer") // begineer, intermediate, advanced
  availablity String // morning, afternoon, evening
  // status Stri
  avatar      String
}

